# Database
DATABASE_URL="postgresql://user:password@localhost:5432/resume_db?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# API
PORT=3000
API_BASE_URL="https://your-domain.com"
NODE_ENV="development"

# LLM Service Authentication
LLM_SERVICE_URL="http://localhost:5000"

# JWT-based authentication (recommended - added Phase 1)
LLM_SERVICE_USERNAME="llm-service"
LLM_SERVICE_PASSWORD="change-me-secure-password-32-chars"

# API Key for accessing LLM service (required)
# This key must match one of the keys in LLM service's LLM_API_KEYS
# Generate with: openssl rand -hex 32
LLM_API_KEY="sk_prod_change_me_api_service_key_here"

# Static token (backward compatibility - optional, will be deprecated)
LLM_SERVICE_TOKEN="your-secure-random-token-here-32-chars-minimum"

# CORS
CORS_ORIGINS="http://localhost:3001,http://localhost:5173"

# Stripe (required - use placeholder values if not using Stripe)
STRIPE_SECRET_KEY="sk_test_placeholder_not_configured"
STRIPE_WEBHOOK_SECRET="whsec_placeholder_not_configured"
STRIPE_PRICE_ID="price_placeholder_not_configured"
# AWS SES - Email Service (optional - required for signup/password change emails)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key-id-here"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key-here"
SES_FROM_EMAIL="noreply@resumecast.ai"
FRONTEND_URL="http://localhost:3001"

# LinkedIn OAuth (optional - for resume import feature)
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/resumes/import/linkedin/callback"