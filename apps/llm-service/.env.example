# Flask Configuration
HOST=0.0.0.0
PORT=5000
FLASK_ENV=production

# LLAMA Model Configuration (for app.py - local model)
LLAMA_MODEL_PATH=./models/llama-2-7b-chat.gguf

# CUDA Configuration (for RTX 3090)
CUDA_VISIBLE_DEVICES=0

# Remote LLAMA Server Configuration (for app_remote.py)
# Uncomment and configure if using an existing LLAMA server

# For llama.cpp server:
# LLAMA_SERVER_URL=http://localhost:8080
# LLAMA_API_TYPE=llama-cpp

# For Ollama:
# LLAMA_SERVER_URL=http://localhost:11434
# LLAMA_API_TYPE=ollama
# OLLAMA_MODEL=llama2

# For OpenAI-compatible API (LocalAI, vLLM, etc.):
# LLAMA_SERVER_URL=http://localhost:8000
# LLAMA_API_TYPE=openai
# MODEL_NAME=llama-2-7b-chat

# Database Configuration (for loading resume from PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/resume_db

# Redis Configuration (shared with API service, using different database)
# API service uses database 0, LLM service uses database 1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Flower Monitoring Dashboard
FLOWER_PORT=5555

# Webhook Security (must match API service)
LLM_WEBHOOK_SECRET=change-me-in-production

# Admin Token (for protected endpoints)
ADMIN_TOKEN=change-me-in-production
